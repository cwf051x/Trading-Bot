EXCHANGE_PROXY=
POLL_INTERVAL_SECONDS=60
KLINE_LIMIT=120
PAPER_LEVERAGE=1
STRATEGY_BREAKOUT_WINDOW=20
STRATEGY_VOLUME_WINDOW=20
STRATEGY_VOLUME_MULTIPLIER=1.5
STRATEGY_STOP_LOSS_PCT=0.02
STRATEGY_TAKE_PROFIT_PCT=0.04
