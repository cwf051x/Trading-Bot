# Python runtime: >=3.11,<3.13
# Production paper mode for Vultr Ubuntu VPS.
# Vultr Ubuntu VPS 生产模拟盘配置模板。
BINANCE_API_KEY=
BINANCE_API_SECRET=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_PROXY=
DATABASE_PATH=data/trading_bot.sqlite
RUN_MODE=paper
ENABLE_LIVE_TRADING=false
BTC_DROP_THRESHOLD_15M=0.03
ACCOUNT_EQUITY=1000
DEFAULT_SYMBOL=BTC/USDT:USDT
WATCH_SYMBOLS=BTC/USDT:USDT,ETH/USDT:USDT,SOL/USDT:USDT,PIPPIN/USDT:USDT,GENIUS/USDT:USDT
